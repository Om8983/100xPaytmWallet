generator client {
  provider   = "prisma-client-js"
  output     = "../generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String         @id @default(uuid())
  email       String         @unique
  phoneNumber Int            @unique
  token       String         @unique // to store the user's jwt token to make sure single login.
  password    String?
  googleID    String?
  Balance     Balance?
  OnRamping   OnRamping[] // this means a single user can have multiple onramp transactions
  Sender      PeerTransfer[] @relation("SenderTransfer")
  Receiver    PeerTransfer[] @relation("ReceiverTransfer")
}

model Balance {
  id      String @id @default(uuid())
  balance Int    @default(0)
  userId  String @unique
  locked  Int    @default(0)
  user    User   @relation(fields: [userId], references: [id])
}

model OnRamping {
  id     String       @id @default(uuid())
  status OnRampStatus

  amount Int
  token  String @unique // generally this is supposed to be the token that the bank server gives us and then based on that we update the user balances across that payment succses and failure...Well for now we can consider it as the token containing an order id or the payment id or refrence id...

  userId String //@unique : bcus making it unique means a user can make an onramp transaction only once not mutliple times.

  provider PROVIDER @default(HDFC_BANK)

  startTime DateTime  @default(now())
  endTime   DateTime?

  user User @relation(fields: [userId], references: [id])
}

enum OnRampStatus {
  Processing
  Failure
  Success
}

enum PROVIDER {
  HDFC_BANK
  ICICI_BANK
  SBI_BANK
}

// in peer to peer transfer the main fields that we will prolly require are
// -> amount to be transferred
// -> who sent
// -> who received
// -> status  of the payment
// -> send at time

model PeerTransfer {
  id              String     @id @default(uuid())
  status          PeerStatus
  amount          Int
  idempotency_key String //will be generated randomly by frontend and stored here.
  receiverId      String // @unique.   the reason i commented this out cuz if the user wants to send money to the same user again then it will create a conflict while transfering since it is suppose to be unique in the table. If you still have issues understanding this then please refer the bottom of the file.
  senderId        String //    @unique

  startTime DateTime  @default(now())
  endTime   DateTime?

  user     User @relation("SenderTransfer", fields: [senderId], references: [id])
  receiver User @relation("ReceiverTransfer", fields: [receiverId], references: [id])
}

enum PeerStatus {
  SUCCESS
  PENDING
  FAILED
}

